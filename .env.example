# Copy to .env.local for local development.
# Do not commit real keys.

PRIMARY_LLM_PROVIDER=groq

# Optional: set this if you use venv/system Python instead of ./.conda/bin/python
PYTHON_BIN=

GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

OPENAI_API_KEY=
OPENAI_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Optional metadata providers
OPEN_LIBRARY_ENABLED=true
GUTENDEX_ENABLED=true

# Optional OCR mode: paste | groq | openai | anthropic | tesseract
OCR_PROVIDER=paste
